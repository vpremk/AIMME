{
  "info": {
    "_postman_id": "a1b2c3d4-aimme-api",
    "name": "AIMME Serverless API",
    "description": "API Gateway routes for AimmeServerlessStack.\nSet collection variable `baseUrl` with **no trailing slash**:\n`https://abc123.execute-api.us-east-1.amazonaws.com/prod`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com/prod"
    },
    {
      "key": "webBaseUrl",
      "value": "https://web-one-rho-28.vercel.app"
    }
  ],
  "item": [
    {
      "name": "GET /signals",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/signals?limit=50",
        "description": "Scan DynamoDB `SignalsTable` (Ingestion Lambda)."
      },
      "response": []
    },
    {
      "name": "POST /signals (ingest raw)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"asset\": \"AAPL\",\n  \"payload\": {\n    \"price\": 190.25,\n    \"volume\": 1500\n  }\n}"
        },
        "url": "{{baseUrl}}/signals",
        "description": "Writes `type=raw`. Optional `timestamp` (ms)."
      },
      "response": []
    },
    {
      "name": "POST /process (manual test)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"asset\": \"AAPL\",\n  \"timestamp\": 1730000000000,\n  \"type\": \"raw\",\n  \"payload\": {\n    \"price\": 100,\n    \"volume\": 2000\n  }\n}"
        },
        "url": "{{baseUrl}}/process",
        "description": "Processing Lambda test (Mangum), bypasses stream."
      },
      "response": []
    },
    {
      "name": "POST /alert (manual test)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"asset\": \"AAPL\",\n  \"timestamp\": 1730000000001,\n  \"type\": \"signal\",\n  \"signal\": \"BUY\",\n  \"score\": 0.95,\n  \"anomaly\": true\n}"
        },
        "url": "{{baseUrl}}/alert",
        "description": "Alerts Lambda → SNS if criteria match."
      },
      "response": []
    },
    {
      "name": "GET /alerts (optional)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/alerts?limit=30",
        "description": "Not implemented in default stack — may 403/404."
      },
      "response": []
    },
    {
      "name": "Web (Next.js)",
      "item": [
        {
          "name": "GET /api/org/branding",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{webBaseUrl}}/api/org/branding",
            "description": "Returns org branding for the current Auth0 enterprise session (orgId/displayName/logo/colors)."
          },
          "response": []
        }
      ]
    }
  ]
}
