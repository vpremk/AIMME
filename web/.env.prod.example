# Production / Vercel — copy to `web/.env.prod` (gitignored) or paste into Vercel → Settings → Environment Variables.
# Loaded by `next.config.js` only when NODE_ENV=production and this file exists (e.g. local `next build`).
# Do not commit a real `.env.prod` with secrets.

# Public API base the browser may use (optional; often same-origin on Vercel).
#NEXT_PUBLIC_API_URL=https://your-app.vercel.app

# Server-side upstream (API Gateway). No trailing slash.
AIMME_API_BASE_URL=https://YOUR_API.execute-api.REGION.amazonaws.com/prod
AIMME_API_KEY=

# Massive API key — required for /api/market/candles (enterprise charts). Set in Vercel env.
MARKET_DATA_API_KEY=

# Polygon (production values as needed)
POLYGON_RPC_URL=
POLYGON_PRIVATE_KEY=
HAZARD_REGISTRY_ADDRESS=
POLYGON_CHAIN_ID=80002
POLYGONSCAN_API_KEY=

NEXT_PUBLIC_DEV_ROLE_OVERRIDE=

# Auth0 — redirect_uri uses request Host by default (preview + prod). AUTH0_BASE_URL still used for SDK / fallbacks.
# Allowed Callback URLs: add each origin you use, or wildcard https://*.vercel.app/api/auth/callback if permitted.
# AUTH0_REDIRECT_URI_FROM_HOST=0 forces fixed {AUTH0_BASE_URL}{AUTH0_CALLBACK} only.
AUTH0_SECRET=
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_BASE_URL=https://your-app.vercel.app
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Optional — only if you use Auth0 Organizations. The org must have at least one connection enabled
# (Dashboard: Organizations → <org> → Connections → enable e.g. Username-Password or Google).
# If set but the org has no connections, login fails with:
#   invalid_request (no connections enabled for the organization)
# For normal tenant-wide login, do NOT set AUTH0_ORGANIZATION (remove it from Vercel if present).
# AUTH0_ORGANIZATION=org_xxxx

# Auth0 Management API (Option A: org metadata-based branding + org details)
# Create a "Machine to Machine Application" in Auth0 and authorize it for the Management API:
#   read:organizations
# Then set:
AUTH0_MGMT_DOMAIN=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
# Optional override (defaults to https://{AUTH0_MGMT_DOMAIN}/api/v2/)
# AUTH0_MGMT_AUDIENCE=
# Cache for /api/org/management and metadata branding lookup (ms). Default 300000.
# AUTH0_ORG_CACHE_TTL_MS=300000

# Org-level UI branding (Option B: AIMME-side table)
# DynamoDB table name containing items keyed by orgId:
#   PK: orgId (string)
#   attributes (optional): displayName, logoUrl, primaryColor, accentColor, badgeText
ORG_BRANDING_TABLE_NAME=
# Fallback config (JSON) if table is not configured. Example:
# ORG_BRANDING_FALLBACK_JSON={"org_abc":{"displayName":"Acme","primaryColor":"#06B6D4","accentColor":"#7C3AED","logoUrl":"https://.../logo.png","badgeText":"Acme"}} 
ORG_BRANDING_FALLBACK_JSON=

# Polygon approval ledger (persist tx records so Approve state survives refresh)
# DynamoDB table name containing items keyed by orgKey+key:
#   PK: orgKey (string)  (see scopeOrgIdForSignals: Auth0 org, per-user sandbox, or public bucket)
#   SK: key (string)     ("ASSET:RISK:TIMESTAMP_MS_FLOOR")
#   attributes: txHash, status, chainId, explorerUrl, lastError?, updatedAt
HAZARD_LEDGER_TABLE_NAME=

POLYGON_SIGNING_MODE=vault
TOKEN_VAULT_URL=http://localhost:8787
# Optional service-to-service auth to your vault
TOKEN_VAULT_SERVICE_TOKEN=
# Optional path override (default /v1/sign/imprint)
TOKEN_VAULT_SIGN_PATH=/v1/sign/imprint
# Optional comma-separated org names/ids for which vault must be disabled.
# Example: Citadel
TOKEN_VAULT_DISABLED_ORGS=Citadel
